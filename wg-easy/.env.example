# Public IP or hostname clients use to reach this VPN server.
WG_HOST=your-server.example.com

# Bcrypt hash of the web UI password (generate with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'your-password')
# Escape every $ as $$ when pasting into this file (Docker Compose variable interpolation).
PASSWORD_HASH=$$2a$$12$$change-me-generate-with-wgpw

LANG=en
WG_EASY_WEB_PORT=51821
WG_EASY_WG_PORT=51820
