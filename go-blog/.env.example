GO_BLOG_HTTP_PORT=8083

# Random string, at least 32 characters (used to sign session cookies).
GO_BLOG_SESSION_SECRET=change-me-session-secret-min-32-chars
# Set to 1 when serving over HTTPS.
GO_BLOG_SESSION_SECURE=0

GO_BLOG_DATABASE_HOST=shared-postgres
GO_BLOG_DATABASE_PORT=5432
GO_BLOG_DATABASE_NAME=goblog
GO_BLOG_DATABASE_USER=goblog
GO_BLOG_DATABASE_PASSWORD=change-me-goblog
